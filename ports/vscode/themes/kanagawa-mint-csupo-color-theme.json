    "tokenColors": [
        { "scope": ["comment", "punctuation.definition.comment"],
          "settings": { "foreground": "#727169", "fontStyle": "italic" } },
        { "scope": ["keyword", "storage.type", "storage.modifier", "keyword.control", "keyword.operator.new", "keyword.operator.expression"],
          "settings": { "foreground": "#b06ecf" } },
        { "scope": ["entity.name.function", "support.function", "meta.function-call.generic"],
          "settings": { "foreground": "#54e3b2" } },
        { "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "entity.other.inherited-class"],
          "settings": { "foreground": "#7e9cd8" } },
        { "scope": ["variable", "variable.parameter", "meta.definition.variable"],
          "settings": { "foreground": "#e6c384" } },
        { "scope": ["variable.other.property", "variable.other.object.property", "support.type.property-name", "meta.object-literal.key", "entity.name.tag.yaml"],
          "settings": { "foreground": "#ff9e3b" } },
        { "scope": ["constant", "constant.language", "constant.numeric.integer", "variable.other.constant", "support.constant", "keyword.other.unit"],
          "settings": { "foreground": "#ff9e3b" } },
        { "scope": ["string", "string.quoted", "markup.inline.raw"],
          "settings": { "foreground": "#98bb6c" } },
        { "scope": ["constant.numeric", "constant.character.numeric"],
          "settings": { "foreground": "#e46876" } },
        { "scope": ["string.regexp", "constant.character.escape"],
          "settings": { "foreground": "#e46876" } },
        { "scope": ["keyword.operator", "punctuation"],
          "settings": { "foreground": "#c8c093" } },
        { "scope": ["entity.name.tag"],
          "settings": { "foreground": "#b06ecf" } },
        { "scope": ["entity.other.attribute-name"],
          "settings": { "foreground": "#e6c384" } },
        { "scope": ["markup.heading"],
          "settings": { "foreground": "#e46876" } },
        { "scope": ["markup.bold"],
          "settings": { "foreground": "#ff9e3b", "fontStyle": "bold" } },
        { "scope": ["markup.italic"],
          "settings": { "foreground": "#54e3b2", "fontStyle": "italic" } },
        { "scope": ["markup.underline.link", "string.other.link"],
          "settings": { "foreground": "#7fb4ca" } },
        { "scope": ["meta.diff.header", "markup.inserted"],
          "settings": { "foreground": "#98bb6c" } },
        { "scope": ["markup.deleted"],
          "settings": { "foreground": "#c34043" } },
        { "scope": ["keyword.other.preprocessor", "meta.preprocessor", "punctuation.definition.decorator", "meta.decorator"],
          "settings": { "foreground": "#b06ecf" } },
        { "scope": ["entity.name.namespace", "entity.name.module", "support.other.namespace"],
          "settings": { "foreground": "#7fb4ca" } }
    ],
    "semanticTokenColors": {
        "function": "#54e3b2",
        "method": "#54e3b2",
        "type": "#7e9cd8",
        "class": "#7e9cd8",
        "interface": "#7e9cd8",
        "enum": "#7fb4ca",
        "namespace": "#7fb4ca",
        "variable": "#e6c384",
        "parameter": { "foreground": "#e6c384", "italic": true },
        "property": "#ff9e3b",
        "enumMember": "#ff9e3b",
        "keyword": "#b06ecf",
        "string": "#98bb6c",
        "number": "#e46876",
        "comment": { "foreground": "#727169", "italic": true }
    }
}
